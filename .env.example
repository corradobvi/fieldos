# ─────────────────────────────────────────────
# FieldOS — variabili d'ambiente
# ─────────────────────────────────────────────
#
# Copia questo file in .env per lo sviluppo locale.
# Su Railway le variabili con (*) vengono impostate
# nel pannello Settings → Variables.
#
# ─────────────────────────────────────────────

# (*) Porta HTTP su cui gira il server.
# Railway la imposta automaticamente — NON configurare su Railway.
PORT=3000

# Percorso base dell'app (es. "/" per dominio root, "/fieldos" per sotto-path).
# Lascia "/" per un deploy standard su Railway.
BASE_PATH=/

# (*) Stringa di connessione MySQL — OBBLIGATORIA per la sincronizzazione cross-device.
#
# Formato:
#   mysql://UTENTE:PASSWORD@HOST:PORTA/DATABASE
#
# Aruba (produzione):
#   mysql://Sql1937173:TUA_PASSWORD@31.11.39.150:3306/Sql1937173_1
#
# Su Railway: Settings → Variables → New Variable
#   Nome:  DATABASE_URL
#   Valore: mysql://Sql1937173:TUA_PASSWORD@31.11.39.150:3306/Sql1937173_1
#
# Sviluppo locale (MySQL in esecuzione su questa macchina):
#   DATABASE_URL=mysql://root:password@127.0.0.1:3306/fieldos_dev
DATABASE_URL=mysql://Sql1937173:PASSWORD@31.11.39.150:3306/Sql1937173_1

# (*) API key Resend per l'invio email (notifica admin su nuova registrazione).
# Su Railway: Settings → Variables → New Variable
#   Nome:  RESEND_API_KEY
#   Valore: re_xxxxxxxxxxxxxxxx
RESEND_API_KEY=

# (*) URL webhook Superchat per avviare il funnel WhatsApp automatico al momento della registrazione.
# Lascia vuoto per disabilitare. La chiamata viene saltata senza errori se non configurata.
# Su Railway: Settings → Variables → New Variable
#   Nome:  SUPERCHAT_WEBHOOK_URL
#   Valore: https://app.superchat.de/api/webhooks/...
SUPERCHAT_WEBHOOK_URL=
